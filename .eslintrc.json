{
    "plugins": [
        "screeps"
    ],
    "env": {
        "screeps/screeps": true,
        "es2021": true,
        "node": true
    },
    "globals": {
        "FIND_TOMBSTONES": "readonly",
        "InterShardMemory": "readonly",
        "STRUCTURE_FACTORY": "readonly",
        "EVENT_ATTACK": "readonly",
        "EVENT_BUILD": "readonly",
        "EVENT_OBJECT_DESTROYED": "readonly",
        "EVENT_HARVEST": "readonly",
        "EVENT_REPAIR": "readonly",
        "EVENT_HEAL": "readonly",
        "FIND_RUINS": "readonly",
        "EVENT_TRANSFER": "readonly",
        "EVENT_WITHDRAW": "readonly"
    },
    "extends": "eslint:recommended",
    "rules": {
        "no-undef": "error",
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
    }
}