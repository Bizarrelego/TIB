{
    "plugins": ["screeps"],
    "env": {
        "screeps/screeps": true,
        "es2021": true,
        "node": true
    },
    "globals": {
        "FIND_TOMBSTONES": "readonly",
        "InterShardMemory": "readonly"
    },
    "extends": "eslint:recommended",
    "rules": {
        "no-undef": "error",
        "no-unused-vars": "warn"
    }
}
